###############################################################################
# .gitignore — GCP Data Engineering Project
###############################################################################

# ── Terraform — Archivos de estado (contienen info sensible) ──────────────────
*.tfstate
*.tfstate.*
*.tfstate.backup
*.tfstate.d/

# Directorio de plugins y providers (se regeneran con terraform init)
.terraform/
.terraform.lock.hcl

# Planes binarios de terraform
*.tfplan
tfplan.binary

# Archivos de override (no deben compartirse)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ── Credenciales y secretos ───────────────────────────────────────────────────
# Claves de Service Account (JSON) — NUNCA subir al repo
*.json
!package.json
!package-lock.json

# Archivos de credenciales de gcloud
gcloud-service-key.json
service-account-key.json
credentials.json
*-credentials.json
*-key.json

# Variables con secretos locales
*.auto.tfvars
secrets.tfvars
local.tfvars

# ── Entornos y configuración local ───────────────────────────────────────────
.env
.env.*
.envrc

# ── Sistema operativo ─────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# ── Editores e IDEs ───────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── Logs y temporales ─────────────────────────────────────────────────────────
*.log
tmp/
temp/
